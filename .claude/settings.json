{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm run sync:skills:check",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "resend@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "mcp__Claude_Code_Remote__create_trigger",
      "mcp__Claude_Code_Remote__update_trigger",
      "mcp__Claude_Code_Remote__delete_trigger",
      "mcp__Claude_Code_Remote__send_later"
    ]
  }
}
