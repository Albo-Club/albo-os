{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "schedule:weekly"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Group all non-major updates into one PR.",
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "non-major"
    },
    {
      "description": "Auto-merge dev dependencies on green CI.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Pinned overrides — bump deliberately, not automatically.",
      "matchPackageNames": [
        "@tanstack/react-router",
        "@tanstack/react-start",
        "@tanstack/router-core",
        "better-call"
      ],
      "enabled": false
    }
  ]
}
