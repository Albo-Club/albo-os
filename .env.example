# All of these are wired up by `pnpm setup` — you usually don't need to edit
# this file by hand. Listed here as a reference and for power users who want
# to skip the wizard.

# ─── Convex ────────────────────────────────────────────────────────────────
# Auto-written by `pnpm exec convex dev` on first run. Don't fill manually.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Same as VITE_CONVEX_URL with .cloud → .site (wizard does this for you).
VITE_CONVEX_SITE_URL=

# ─── Better Auth ────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET lives in the Convex env (not here). Auto-generated by
# `pnpm setup`; in prod, `pnpm setup:prod` generates a fresh one.
# BETTER_AUTH_URL also lives in the Convex env; default = http://localhost:3000.

# ─── OpenRouter ─────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY lives in the Convex env (not here).
# OPENROUTER_MODEL optionally overrides the default deepseek/deepseek-v4-pro.
# → Get yours: https://openrouter.ai/keys

# ─── Resend ─────────────────────────────────────────────────────────────────
# RESEND_API_KEY and RESEND_FROM live in the Convex env (not here).
# → API key:        https://resend.com/api-keys
# → Verified domain: https://resend.com/domains  (use onboarding@resend.dev for dev)

# ─── AgentMail (report ingestion by email) ──────────────────────────────────
# All live in the Convex env (not here). Inbound reports are sent to
# report-albo-os@agentmail.to and processed by the report pipeline.
# AGENTMAIL_API_KEY        — API key (https://agentmail.to)
# AGENTMAIL_INBOX_ID       — inbox id for report-albo-os@agentmail.to (fallback
#                            when a webhook event omits inbox_id)
# AGENTMAIL_WEBHOOK_SECRET — Svix signing secret (whsec_…) for the webhook at
#                            <CONVEX_SITE_URL>/agentmail/webhook
# MISTRAL_API_KEY          — OCR of PDF/image attachments (mistral-ocr-latest).
#                            Optional: without it, only the email body is analyzed.
# JINA_API_KEY             — Jina Reader (r.jina.ai), headless rendering of
#                            public Notion pages (Notion's internal API is dead,
#                            cf. KNOWN_ISSUES.md « Notion : extraction »). Free
#                            key at https://jina.ai — without it, Notion links
#                            fail with an actionable message.

# ─── Linkup (web search for company-intelligence synthesis) ─────────────────
# LINKUP_API_KEY lives in the Convex env. Without it, the synthesis still runs
# but skips web enrichment. → https://www.linkup.so

# ─── Google OAuth (optional, social login) ─────────────────────────────────
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET live in the Convex env (not here).
# Leave unset to ship without the Google button (it only renders when both are
# present). `pnpm setup` prompts for these in dev; `pnpm setup:prod` mirrors
# them to prod.
# → Create an OAuth client: https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI (dev):  http://localhost:3000/api/auth/callback/google
#   Authorized redirect URI (prod): https://<your-domain>/api/auth/callback/google
#   (register BOTH on the same client; see KNOWN_ISSUES.md § Google OAuth)

# ─── Sentry (optional, front-end) ──────────────────────────────────────────
# Back-end (SENTRY_DSN, SENTRY_*) lives in the Convex env. Front-end DSN below
# is build-time inlined into the bundle.
# → Get yours: https://sentry.io/settings/{org}/projects/{project}/keys/
VITE_SENTRY_DSN=

# ─── logo.dev (optional, company logos) ─────────────────────────────────────
# Publishable key (pk_…) for portfolio company logos. NOT a secret — it's
# meant to be embedded client-side, so the VITE_ prefix is fine. Logos fall
# back to a placeholder icon when unset.
# → Get yours: https://www.logo.dev (publishable key)
VITE_LOGO_DEV_TOKEN=
