{
  "name": "albo-os",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,convex -c blue,magenta \"pnpm dev:vite\" \"pnpm dev:convex\"",
    "dev:vite": "vite dev",
    "dev:convex": "convex dev",
    "build": "vite build && tsc --noEmit",
    "build:vercel": "if [ \"$VERCEL_ENV\" = \"production\" ] && [ -n \"$CONVEX_DEPLOY_KEY\" ]; then npx convex deploy --cmd 'pnpm build' && npx convex run transactions:backfillSearchText '{}' && npx convex run transactions:backfillMatchStatus '{}'; else echo '[albo-os] Skipping convex deploy (not Vercel production env or CONVEX_DEPLOY_KEY missing).'; pnpm build; fi",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "sync:skills": "node scripts/sync-skills.mjs",
    "sync:skills:check": "node scripts/sync-skills.mjs --check",
    "setup": "node scripts/setup.mjs",
    "setup:prod": "node scripts/setup-prod.mjs",
    "init": "node scripts/init.mjs",
    "upgrade-template": "node scripts/upgrade-template.mjs",
    "test:smoke": "node scripts/e2e-smoke.mjs",
    "test:cookies": "bash scripts/test-cookies.sh",
    "test:unit": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/better-auth": "^0.12.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/workpool": "^0.4.6",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@sentry/react": "^10.52.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-with-query": "1.130.17",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "ai": "^6.0.177",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.116",
    "date-fns": "^4.1.0",
    "i18next": "^26.2.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "nitro": "3.0.260429-beta",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260522.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
